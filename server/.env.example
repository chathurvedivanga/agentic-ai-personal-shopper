GEMINI_API_KEY=gemini-api-key-placeholder
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.0-flash,gemini-flash-latest
OPENROUTER_API_KEY=openrouter-api-key-placeholder
OPENROUTER_APP_TITLE=AI Shopping Partner
OPENROUTER_HTTP_REFERER=http://localhost:5173
PORT=5000
CORS_ORIGIN=http://localhost:5173
# Optional locally. Leave empty for SQLite, or paste your Neon Postgres URL.
# Neon URLs should include sslmode=require.
DATABASE_URL=
DB_PATH=agentic_shopper.db
